using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.Logging;
using Core.Contracts.NomeEntidadeContract.Request;
using Core.Entities;
using Core.Pagination;
using Core.Repositories.Interfaces;
using Infra.Context;

namespace Infra.Repositories
{
    public class NomeEntidadeRepository(
        ApplicationDbContext context,
        ILogger<NomeEntidadeRepository> logger)
        : BaseRepository<NomeEntidade>(context),
          INomeEntidadeRepository
    {
        private readonly ILogger<NomeEntidadeRepository> _logger = logger;

        public async Task<NomeEntidade?> GetById(long id)
        {
            return await _context.Set<NomeEntidade>()
                .FirstOrDefaultAsync(x => x.NomePk == id);
        }

        public async Task<ResponsePagedSearch<NomeEntidade>> FindPaged(FindNomeEntidade request)
        {
            var query = _context.Set<NomeEntidade>()
                .AsNoTracking()
                .AsQueryable();

            if (request.NomePk.HasValue)
                query = query.Where(x => x.NomePk == request.NomePk.Value);

            if (!string.IsNullOrWhiteSpace(request.NomeCampo))
                query = query.Where(x => x.NomeCampo != null &&
                    x.NomeCampo.ToUpper().Contains(request.NomeCampo.ToUpper()));

            return await query.ToPagedSearchAsync(request);
        }
    }
}

Regras:

- Usar AsNoTracking no Find.
- Aplicar filtro de soft delete quando existir.
- Incluir Includes somente se necessário.
- Aplicar filtros dinâmicos.
- Não carregar navegações desnecessárias.
- GetById pode usar tracking para update.

