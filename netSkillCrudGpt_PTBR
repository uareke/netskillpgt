using AutoMapper;
using Microsoft.Extensions.Logging;
using Core.Contracts.NomeEntidadeContract.Request;
using Core.Contracts.NomeEntidadeContract.Response;
using Core.Entities;
using Core.Pagination;
using Core.Repositories.Interfaces;
using Domain.Exceptions;
using Domain.Services.Interfaces;

namespace Domain.Services
{
    public class NomeEntidadeService(
        ILogger<NomeEntidadeService> logger,
        INomeEntidadeRepository repository,
        IMapper mapper)
        : INomeEntidadeService
    {
        private readonly INomeEntidadeRepository _repository = repository;
        private readonly IMapper _mapper = mapper;
        private readonly ILogger<NomeEntidadeService> _logger = logger;

        public async Task<ResponsePagedSearch<ResponseNomeEntidade>> Find(FindNomeEntidade request)
        {
            var result = await _repository.FindPaged(request);
            return _mapper.Map<ResponsePagedSearch<ResponseNomeEntidade>>(result);
        }

        public async Task<ResponseNomeEntidade> Create(CreateNomeEntidade request)
        {
            var entity = _mapper.Map<NomeEntidade>(request);

            await _repository.CreateAsync(entity);
            await _repository.SaveChangesAsync();

            return _mapper.Map<ResponseNomeEntidade>(entity);
        }

        public async Task<ResponseNomeEntidade> Update(UpdateNomeEntidade request)
        {
            var entity = await _repository.GetById(request.NomePk!.Value);

            if (entity == null)
                throw new NotFoundException("Registro não encontrado.");

            _mapper.Map(request, entity);

            await _repository.UpdateAsync(entity);
            await _repository.SaveChangesAsync();

            return _mapper.Map<ResponseNomeEntidade>(entity);
        }

        public async Task Delete(long id)
        {
            var entity = await _repository.GetById(id);

            if (entity == null)
                throw new NotFoundException("Registro não encontrado.");

            await _repository.DeleteAsync(entity);
            await _repository.SaveChangesAsync();
        }
    }
}

